      <aliases enabled='yes' />
      <column caption='DELIVERY STATUS' datatype='string' name='[Calculation_1220220972507136]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days_diff] &lt; 0 THEN &quot;Early&quot;&#13;&#10;ELSEIF [delivery_days_diff] = 0 THEN &quot;On Time&quot;&#13;&#10;ELSE &quot;Late&quot;&#13;&#10;END' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_1220220984635393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_order_value]) / COUNT([order_id])' />
      </column>
      <column caption='DELV PACE' datatype='real' name='[Calculation_1220220985405442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(DATEDIFF(&apos;day&apos;, [order_purchase_timestamp], [order_delivered_customer_date]))' />
      </column>
